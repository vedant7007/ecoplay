# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Database Configuration (for local development)
# Not used - this project connects to Supabase via VITE_SUPABASE_URL above.
# Uncomment only if running a local PostgreSQL instance outside Supabase.
# DATABASE_URL=postgresql://username:password@localhost:5432/ecoplay

# JWT Secret (for local auth)
# Not used - Supabase Auth handles JWT internally.
# Uncomment only if implementing a custom auth server.
# JWT_SECRET=your-jwt-secret-key

# Environment
NODE_ENV=development

# Service Worker (optional — enable SW in Vite dev for offline/cache testing)
# VITE_ENABLE_SW=true
